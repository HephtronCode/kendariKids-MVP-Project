{
  "name": "kendarikids-workspace",
  "version": "1.0.0",
  "description": "Root workspace orchestrator for KendariKids",
  "scripts": {
    "install:all": "cd server && pnpm install && cd ../client && pnpm install",
    "dev:server": "cd server && pnpm run dev",
    "dev:client": "cd client && pnpm run dev",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\""
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
